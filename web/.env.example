# Supabase (server-only, NUNCA NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate-limit distribuido). Si no se configura, cae a in-memory.
# Provisionar via Vercel Marketplace → Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (anti-bot). Si no se configura, el form prescinde del widget.
# https://dash.cloudflare.com → Turnstile → add site tramarca.es
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
