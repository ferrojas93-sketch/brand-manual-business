# Supabase (server-only, NUNCA NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (rate-limit distribuido). Si no se configura, cae a in-memory.
# Acepta cualquier Redis TCP: Redis Cloud, Upstash (rediss://), Railway, self-hosted.
# Provisionar via Vercel Marketplace → Storage → Redis.
REDIS_URL=

# Cloudflare Turnstile (anti-bot). Si no se configura, el form prescinde del widget.
# https://dash.cloudflare.com → Turnstile → add site tramarca.es
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (email notificaciones de nuevos leads). Si falta, lead se guarda sin alerta.
# https://resend.com → API Keys
RESEND_API_KEY=
LEAD_NOTIFY_TO=hola@tramarca.es
LEAD_NOTIFY_FROM=leads@tramarca.es
